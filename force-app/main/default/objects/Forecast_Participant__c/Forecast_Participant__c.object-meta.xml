    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <label>Forecast Participant</label>
    <nameField><label>Forecast Participant Number</label><displayFormat>FP-{00000}</displayFormat><type>AutoNumber</type></nameField>
    <pluralLabel>Forecast Participants</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
</CustomObject>
