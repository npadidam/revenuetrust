<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Tracks each hierarchy synchronisation run, recording counts of participants created, updated, or deactivated and any errors.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <label>Hierarchy Sync Log</label>
    <nameField><label>Hierarchy Sync Log Number</label><displayFormat>HSL-{00000}</displayFormat><type>AutoNumber</type></nameField>
    <pluralLabel>Hierarchy Sync Logs</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
</CustomObject>
