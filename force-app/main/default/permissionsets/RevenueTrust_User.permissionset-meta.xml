<?xml version="1.0" encoding="UTF-8" ?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <applicationVisibilities>
        <application>RevenueTrust</application>
        <visible>true</visible>
    </applicationVisibilities>
    <description
  >Standard user access to RevenueTrust forecasting. Allows viewing forecasts, editing own overrides, and submitting. Assign to sales reps and contributors.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>RevenueTrust User</label>
    <tabSettings>
        <tab>REVT_Forecast</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- Forecast Configuration — Read Only -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Forecast_Configuration__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
